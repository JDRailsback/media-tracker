# Copy this file to ".env" and fill in real values. ".env" is gitignored.
# Vapor automatically loads ".env" in development.

# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# IGDB is authenticated through a Twitch app:
# register one at https://dev.twitch.tv/console/apps
IGDB_CLIENT_ID=your_twitch_client_id_here
IGDB_CLIENT_SECRET=your_twitch_client_secret_here

# Postgres connection for local development.
# On a host (Fly.io, Railway, …) this is usually provided for you.
DATABASE_URL=postgres://mediatracker:mediatracker@localhost:5432/mediatracker

# APNs (push notifications) — from your Apple Developer account.
# Leave unset in dev to boot without push. The private key is the .p8 file's
# contents (keep the newlines / PEM header + footer).
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
...your .p8 contents...
-----END PRIVATE KEY-----"
APNS_KEY_ID=your_10_char_key_id
APNS_TEAM_ID=your_10_char_team_id
APNS_TOPIC=com.yourname.mediatracker
