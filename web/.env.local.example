# Copy to .env.local and fill in. .env.local is gitignored.

# --- Data sources ---
# https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
# https://dev.twitch.tv/console/apps
IGDB_CLIENT_ID=your_twitch_client_id_here
IGDB_CLIENT_SECRET=your_twitch_client_secret_here
# https://trakt.tv/oauth/applications -> New Application (public GET endpoints
# like movies/anticipated only need the Client ID, no OAuth/Client Secret).
TRAKT_CLIENT_ID=your_trakt_client_id_here

# --- Database (Neon Postgres) ---
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# --- Web Push (VAPID) ---
# Generate a pair with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:you@example.com
# Same public key, exposed to the browser:
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key

# --- Poller ---
# Vercel Cron sends this as a Bearer token; set the same value in Vercel.
CRON_SECRET=any_long_random_string
